rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /polls/{pollId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;
      allow update: if request.auth != null && (
        // Enforce voting rules
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votesA', 'votesB', 'voters']) &&
          !(request.auth.uid in resource.data.voters) &&
          (request.auth.uid in request.resource.data.voters) &&
          (
            (request.resource.data.voters[request.auth.uid] == 0 && request.resource.data.votesA == resource.data.votesA + 1 && request.resource.data.votesB == resource.data.votesB) ||
            (request.resource.data.voters[request.auth.uid] == 1 && request.resource.data.votesB == resource.data.votesB + 1 && request.resource.data.votesA == resource.data.votesA)
          )
        ) ||
        // Allow owner modifications
        resource.data.createdBy == request.auth.uid
      );
      allow delete: if request.auth != null && resource.data.createdBy == request.auth.uid;
    }
  }
}
